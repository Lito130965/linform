{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noUnusedLocals": true
  },
  "include": ["src"],
  // Tests are vitest's business (they use node builtins the app must not);
  // the app build type-checks application code only.
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
